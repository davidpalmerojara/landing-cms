# Caddyfile — Reverse proxy with automatic SSL for custom domains
#
# Caddy automatically provisions and renews Let's Encrypt certificates
# for any domain that resolves to this server. No manual SSL setup needed.
#
# Architecture:
#   Internet → Caddy (:80/:443) → Next.js (:3000) / Django (:8001)
#
# Requirements:
#   - Caddy v2.7+
#   - Ports 80 and 443 open (Let's Encrypt HTTP-01 challenge)
#   - DNS for each custom domain pointing to this server's IP
#
# Usage:
#   caddy run --config Caddyfile
#   caddy reload --config Caddyfile   # after changes, zero-downtime

# ─── Global options ──────────────────────────────────────────────
{
	# Email for Let's Encrypt account (rate limit notifications)
	email admin@builderpro.com

	# Staging CA for testing (uncomment to avoid rate limits during dev):
	# acme_ca https://acme-staging-v02.api.letsencrypt.org/directory

	# On-demand TLS: provisions certificates automatically when a
	# request arrives for an unknown domain. The `ask` endpoint
	# ensures we only provision for domains we actually own.
	on_demand_tls {
		ask http://localhost:8001/api/public/resolve-domain/
		interval 5m
		burst 10
	}
}

# ─── Main app domain ────────────────────────────────────────────
app.builderpro.com {
	# Frontend (Next.js)
	reverse_proxy localhost:3000

	# Backend API
	handle /api/* {
		reverse_proxy localhost:8001
	}

	# Django admin
	handle /admin/* {
		reverse_proxy localhost:8001
	}

	# Django static files
	handle /static/* {
		reverse_proxy localhost:8001
	}

	# WebSocket for collaboration (future)
	handle /ws/* {
		reverse_proxy localhost:8001
	}
}

# ─── Marketing site ─────────────────────────────────────────────
builderpro.com, www.builderpro.com {
	# Redirect www to apex
	@www host www.builderpro.com
	redir @www https://builderpro.com{uri} permanent

	reverse_proxy localhost:3000
}

# ─── Custom domains (catch-all with on-demand TLS) ──────────────
# Any domain not matched above gets on-demand TLS.
# Caddy will call the `ask` endpoint to verify the domain is ours
# before provisioning a certificate.
:443 {
	tls {
		on_demand
	}

	# All custom domain traffic goes to Next.js.
	# The Next.js middleware resolves the Host header to a page slug
	# and rewrites to /p/[slug].
	reverse_proxy localhost:3000
}

# ─── HTTP fallback (redirect to HTTPS) ──────────────────────────
:80 {
	redir https://{host}{uri} permanent
}
